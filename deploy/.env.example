# Clé de chiffrement des pushes (générer avec: openssl rand -hex 32)
PWPUSH_MASTER_KEY=CHANGE_ME

# Configuration app
PWP__ALLOWED_HOSTS=secrets.collectifweb.ca
PWP__HOST_DOMAIN=secrets.collectifweb.ca
PWP__HOST_PROTOCOL=https

# Locale forcée à français
PWP__DEFAULT_LOCALE=fr
PWP__ENABLED_LANGUAGE_CODES=fr

# Branding Collectif
PWP__BRAND__TITLE=Espace secret du Collectif
PWP__BRAND__TAGLINE=Envoyez vos secrets les plus deep. Une fois lus, ils disparaîtront ensuite à tout jamais. Promis !

# Features
PWP__ENABLE_LOGINS=false
PWP__ENABLE_FILE_PUSHES=false
PWP__ENABLE_URL_PUSHES=false
PWP__ENABLE_QR_PUSHES=false
PWP__PW__ENABLE_DELETABLE_PUSHES=true
PWP__PW__DELETABLE_PUSHES_DEFAULT=true

# Expiration — bornes alignées avec le menu déroulant CW (cw-custom.js)
PWP__PW__EXPIRE_AFTER_DAYS_DEFAULT=7
PWP__PW__EXPIRE_AFTER_DAYS_MIN=1
PWP__PW__EXPIRE_AFTER_DAYS_MAX=30
PWP__PW__EXPIRE_AFTER_VIEWS_DEFAULT=1
PWP__PW__EXPIRE_AFTER_VIEWS_MIN=1
PWP__PW__EXPIRE_AFTER_VIEWS_MAX=15

# Timezone
PWP__TIMEZONE=America/Toronto

# Recompile assets on boot (needed for custom.css volume mount)
PWP_PRECOMPILE=true
